# =============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - BOOKSHOP APP
# =============================================================================
# Copia este archivo a .env y configura los valores apropiados
# IMPORTANTE: Nunca subas el archivo .env al repositorio
# =============================================================================

# =============================================================================
# BASE DE DATOS (PostgreSQL)
# =============================================================================
DATASOURCE_URL=jdbc:postgresql://localhost:5432/bookshop
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=tu_password_seguro_aqui

# =============================================================================
# JWT (JSON Web Token) - Seguridad
# =============================================================================
# Clave secreta para firmar tokens JWT (mínimo 256 bits / 32 caracteres)
# Genera una clave segura, por ejemplo: openssl rand -base64 32
JWT_SECRET=tu_clave_secreta_jwt_minimo_32_caracteres

# Tiempo de expiración del token en milisegundos
# 86400000 = 24 horas
# 3600000 = 1 hora
JWT_EXPIRATION=86400000
